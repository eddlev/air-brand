{
  "$meta": {
    "brand": "AIR by VM4AI",
    "tagline": "Configure. Organize. Execute.",
    "support_line": "Structure for any AI work.",
    "origin": "PROMPT_COMPILED",
    "backend_validation_claimed": false,
    "theming": "auto (prefers-color-scheme) with manual override via data-theme; accents constant, neutrals invert",
    "note": "Companion to air-tokens.css. Values are identical."
  },
  "color": {
    "brand": {
      "brass":      { "value": "#C9A227", "use": "structure / identity — freely" },
      "ember":      { "value": "#FF5A1F", "use": "active step / Orbit 0 signal — sparingly" },
      "foundation": { "value": "#1A1613", "use": "canonical dark reference" },
      "paper":      { "value": "#F5F4F2", "use": "canonical light reference" },
      "on-accent":  { "value": "#1A1613", "use": "text/icon placed on brass or ember fills" }
    },
    "theme": {
      "dark": {
        "bg": "#1A1613",
        "surface": "#221C18",
        "surface-2": "#2A231D",
        "text": "#ECE4D8",
        "text-muted": "#9A8F80",
        "text-subtle": "#6E655B",
        "border": "rgba(236,228,216,0.12)",
        "border-strong": "rgba(236,228,216,0.24)"
      },
      "light": {
        "bg": "#F5F4F2",
        "surface": "#FFFFFF",
        "surface-2": "#FAFAF8",
        "text": "#1A1613",
        "text-muted": "#6E665C",
        "text-subtle": "#8A8278",
        "border": "rgba(26,22,19,0.12)",
        "border-strong": "rgba(26,22,19,0.22)"
      }
    },
    "semantic": {
      "_note": "Tuned to never collide with brass (gold) or ember (orange): warning is a distinct amber, error a true red, info a slate blue, success green.",
      "dark": {
        "success": "#56B581", "success-bg": "rgba(86,181,129,0.14)",
        "warning": "#E6B53C", "warning-bg": "rgba(230,181,60,0.14)",
        "error":   "#E86A6A", "error-bg":   "rgba(232,106,106,0.14)",
        "info":    "#5B8FD6", "info-bg":    "rgba(91,143,214,0.14)"
      },
      "light": {
        "success": "#2F9E68", "success-bg": "rgba(47,158,104,0.12)",
        "warning": "#B7791F", "warning-bg": "rgba(183,121,31,0.12)",
        "error":   "#D64545", "error-bg":   "rgba(214,69,69,0.10)",
        "info":    "#3E78C2", "info-bg":    "rgba(62,120,194,0.10)"
      }
    }
  },
  "typography": {
    "font": {
      "display": "'Space Grotesk', ui-sans-serif, system-ui, sans-serif",
      "body":    "'Space Grotesk', ui-sans-serif, system-ui, sans-serif",
      "mono":    "'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace"
    },
    "weight": { "regular": 400, "medium": 500, "bold": 700 },
    "scale": {
      "display": { "size": "clamp(2.5rem, 1.75rem + 3.4vw, 3.5rem)", "line-height": 1.04, "tracking": "-0.02em",  "weight": 700 },
      "h1":      { "size": "clamp(2rem, 1.55rem + 1.9vw, 2.5rem)",   "line-height": 1.1,  "tracking": "-0.015em", "weight": 700 },
      "h2":      { "size": "1.875rem", "line-height": 1.2, "tracking": "-0.01em",  "weight": 500 },
      "h3":      { "size": "1.375rem", "line-height": 1.3, "tracking": "-0.005em", "weight": 500 },
      "body":    { "size": "1rem",     "line-height": 1.6, "tracking": "0",        "weight": 400 },
      "small":   { "size": "0.875rem", "line-height": 1.5, "tracking": "0",        "weight": 400 },
      "caption": { "size": "0.75rem",  "line-height": 1.4, "tracking": "0.04em",   "weight": 400, "transform": "uppercase", "font": "mono" }
    }
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "16px", "pill": "999px" },
  "spacing": {
    "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem",
    "5": "1.5rem",  "6": "2rem",   "7": "3rem",    "8": "4rem"
  },
  "font_files": {
    "format_shipped": "woff",
    "format_preferred": "woff2",
    "path": "fonts/",
    "files": [
      "space-grotesk-400", "space-grotesk-500", "space-grotesk-700", "jetbrains-mono-400"
    ],
    "license": "SIL Open Font License 1.1"
  }
}
